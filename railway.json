{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksJson": {
      " aptitude": [],
      "python": {
        "versionSource": "runtimeDockerfile",
        "versions": ["3.12"]
      },
      "packages": ["libpq"]
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "sleep": "300s"
  }
}
