# Base mainnet
BASE_RPC_URL=https://mainnet.base.org
PRIVATE_KEY=0xYOUR_TRADER_PRIVATE_KEY
TRADER_ADDRESS=0xYOUR_TRADER_ADDRESS
REPUTATION_PRIVATE_KEY=0xYOUR_REVIEWER_PRIVATE_KEY
REPUTATION_ADDRESS=0xYOUR_REVIEWER_ADDRESS

# LLMs
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
VENICE_API_KEY=
VENICE_MODEL=llama-3.3-70b
VENICE_API_URL=https://api.venice.ai/api/v1/chat/completions
BANKR_API_KEY=
BANKR_MODEL=gpt-4.1-mini
BANKR_API_URL=https://api.bankr.bot/v1/chat/completions

# Uniswap Developer Platform
UNISWAP_API_KEY=
UNISWAP_QUOTE_URL=https://trade-api.gateway.uniswap.org/v1/quote

# Optional service endpoints shown in agent.json
PUBLIC_APP_URL=https://example.com
A2A_URL=https://example.com/.well-known/agent-card.json
MCP_URL=https://example.com/mcp
STREAMLIT_URL=https://example.com/dashboard

# Risk + autonomy
EMERGENCY_STOP=false
EMERGENCY_STOP_FILE=.emergency_stop
MAX_TRADE_PCT=5
MAX_SLIPPAGE_BPS=100
MAX_GAS_ETH=0.005
SLEEP_SECONDS=3600

# Optional Bankr budget tracking
BANKR_BUDGET_USD=0
